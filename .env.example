# DWIGHT environment configuration (LOCAL DEVELOPMENT)
# Copy to `.env` and adjust as needed.

# ---- Public (exposed to client via $env/static/public) ----
PUBLIC_APP_NAME="DWIGHT"
PUBLIC_APP_URL="http://localhost:5174"

# ---- Server (private) ----
DATABASE_URL="postgres://dwight:dwight@localhost:5433/dwight"

# JWT signing secret. MUST be at least 32 random bytes for production.
# Generate with: openssl rand -base64 48
AUTH_SECRET="dev-only-change-me-min-32-chars-1234567890abcd"

# Cookie name for the session JWT.
SESSION_COOKIE="dwight_session"

# Admin promotion secret. Required for the 9-click easter-egg admin login.
# Set to a strong unguessable value in production (min 8 chars).
ADMIN_SECRET="change-me-admin"

# Optional: Redis (deferred to V2 SSE multi-instance fan-out).
REDIS_URL="redis://localhost:6380"
